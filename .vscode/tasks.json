{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build project",
            "type": "shell",
            "command": "make", // Or your specific build command
            "group": "build"
        },
        {
            "label": "Start OpenOCD",
            "type": "shell",
            "isBackground": true,
            "command": "openocd",
            "args": [
                "-f", "interface/stlink.cfg", // Adjust for your debugger
                "-f", "target/stm32g4x.cfg"   // Adjust for your MCU
            ],
            "problemMatcher": [
                {
                    "pattern": { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "Open On-Chip Debugger",
                        "endsPattern": "Listening on port 3333 for gdb connections"
                    }
                }
            ]
        }
    ]
}