{
    "configurations": [
        {
            "name": "STM32",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/Core/Inc",
                "${workspaceFolder}/Core/Src",
                "${workspaceFolder}/Drivers/STM32G4xx_HAL_Driver/Inc",
                "${workspaceFolder}/Drivers/STM32G4xx_HAL_Driver/Inc/Legacy",
                "${workspaceFolder}/Drivers/CMSIS/Include",
                "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32G4xx/Include",
                "${workspaceFolder}/USB_Device/App",
                "${workspaceFolder}/Drivers/**",
                "${workspaceFolder}/Middlewares/**",
                "${workspaceFolder}/USB_Device/**",
                "${workspaceFolder}/App/Inc/",
                "${workspaceFolder}/App/Src/"
            ],
            "defines": [
                "USE_HAL_DRIVER",
                "STM32G474xx"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-arm",
            "browse": {
                "path": [
                    "${workspaceFolder}/Core",
                    "${workspaceFolder}/Drivers",
                    "${workspaceFolder}/App",
                    "${workspaceFolder}/USB_Device"
                ],
                "limitSymbolsToIncludedHeaders": true,
                "databaseFilename": ""
            }
        }
    ],
    "version": 4
}